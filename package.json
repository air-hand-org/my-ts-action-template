{
  "name": "my-ts-action-template",
  "description": "GitHub Actions TypeScript template",
  "version": "1.0.6",
  "author": "",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/air-hand/my-ts-action-template",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/air-hand/my-ts-action-template.git"
  },
  "bugs": {
    "url": "https://github.com/air-hand/my-ts-action-template/issues"
  },
  "keywords": [
    "actions"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx @biomejs/biome format --write .",
    "format:check": "npx @biomejs/biome check --formatter-enabled=true --linter-enabled=false .",
    "lint": "npx @biomejs/biome check --formatter-enabled=false --linter-enabled=true .",
    "local-action": "npx local-action . src/main.ts .env",
    "package": "npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "upgrade": "npx npm-check-updates -u",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@github/local-action": "^7.0.1",
    "@jest/globals": "^30.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "make-coverage-badge": "^1.2.0",
    "npm-check-updates": "^22.0.0",
    "rollup": "^4.31.0",
    "ts-jest": "^29.4.9",
    "ts-jest-resolver": "^2.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
