{
  extends: [
    'github>aquaproj/aqua-renovate-config#2.6.0',
    'helpers:pinGitHubActionDigests',
  ],
  prConcurrentLimit: 10,
  enabledManagers: ['custom.regex', 'mise', 'npm', 'github-actions'],
  labels: ['dependencies'],
  assigneesFromCodeOwners: true,
  packageRules: [
    {
      matchSourceUrls: [
        'https://github.com/air-hand-org/**',
        'https://github.com/actions/**',
      ],
      minimumReleaseAge: '0 days',
    },
    {
      matchUpdateTypes: ['major'],
      addLabels: ['major']
    },
    {
      matchUpdateTypes: ['minor'],
      addLabels: ['minor'],
      automerge: true,
    },
    {
      matchUpdateTypes: ['patch'],
      addLabels: ['patch'],
      automerge: true,
    }
  ],
  mise: {
    managerFilePatterns: [
      '(^|/)\\.?mise\\.toml$',
      '(^|/)\\.?mise/config\\.toml$',
      '(^|/)\\.?mise/config.*\\.toml$'
    ]
  },
  // Ignore CI commits from the release app so Renovate keeps rebasing/updating its PR branches.
  gitIgnoredAuthors: [
    '276784480+air-hand-release-app[bot]@users.noreply.github.com',
  ],
  rebaseWhen: "behind-base-branch",
  minimumReleaseAge: "3 days",
}
